# Normalize line endings across OSes
* text=auto

# Force LF for all content and config files
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.rb text eol=lf
*.txt text eol=lf

# Binary files — don't touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
