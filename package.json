{
  "name": "dnsimple-support",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "dependencies": {
    "fuse.js": "^7.4.2",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "@vue/vue3-jest": "^29.2.6",
    "babel-jest": "^30.4.1",
    "concurrently": "^10.0.3",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "rollup-plugin-css-only": "^4.5.5",
    "sass-embedded": "^1.100.0",
    "tachyons": "^4.12.0",
    "vite": "^8.0.16",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vue-eslint-parser": "^10.4.1",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.1.0"
  },
  "scripts": {
    "live": "concurrently 'bundle exec nanoc live' 'bundle exec rake compile'",
    "build": "./node_modules/.bin/webpack && vite build ./_widget",
    "lint": "eslint _widget src spec",
    "lint:fix": "eslint _widget src spec --fix",
    "widget": "vite serve ./_widget",
    "test": "bundle exec rake compile && jest",
    "test:watch": "jest --watch"
  },
  "resolutions": {
    "js-yaml": "^4.1.1"
  }
}
